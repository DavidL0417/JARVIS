NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DIALOGUE_MODEL=claude-sonnet-4-6
CRON_SECRET=
# Read-only bearer token for GET /api/automation-status (local scheduled-task pause probe).
# Separate from CRON_SECRET on purpose: read-only, lower-stakes.
AUTOMATION_STATUS_TOKEN=
# Operator profile id the token-authed status probe resolves to when more than
# one profile exists. Optional for single-profile deployments.
AUTOMATION_OWNER_USER_ID=

# Operator-only iMessage intake (hidden backend; see docs/decisions/operator-only-imessage.md).
# BOTH must be set for POST /api/integrations/imessage/ingest to exist — unset = 404.
# IMESSAGE_INGEST_SECRET: long random string the local reader sends as a Bearer token.
# IMESSAGE_OPERATOR_USER_ID: the operator's profiles.id; every ingested message is written to it.
IMESSAGE_INGEST_SECRET=
IMESSAGE_OPERATOR_USER_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
