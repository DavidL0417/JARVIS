{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/source-refresh",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/memory-consolidate",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/infer-deadlines",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "*/30 * * * *"
    }
  ]
}
